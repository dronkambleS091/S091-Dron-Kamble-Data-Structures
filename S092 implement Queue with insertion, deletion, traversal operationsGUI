import tkinter as tk
from tkinter import messagebox

queue = []

# Function to set maximum size
def set_size():
    global max_size
    try:
        max_size = int(size_entry.get())
        messagebox.showinfo("Success", f"Queue size set to {max_size}")
    except:
        messagebox.showerror("Error", "Enter a valid number")

# Enqueue
def enqueue():
    if len(queue) == max_size:
        messagebox.showwarning("Queue", "Queue is Full!")
    else:
        item = item_entry.get()
        if item == "":
            messagebox.showwarning("Queue", "Enter an item")
            return
        queue.append(item)
        item_entry.delete(0, tk.END)
        display_queue()

# Dequeue
def dequeue():
    if len(queue) == 0:
        messagebox.showwarning("Queue", "Queue is Empty!")
    else:
        item = queue.pop(0)
        messagebox.showinfo("Dequeued", f"Removed: {item}")
        display_queue()

# Peek
def peek():
    if len(queue) == 0:
        messagebox.showwarning("Queue", "Queue is Empty!")
    else:
        messagebox.showinfo("Front Element", queue[0])

# Traverse
def traverse():
    if len(queue) == 0:
        messagebox.showwarning("Queue", "Queue is Empty!")
    else:
        messagebox.showinfo("Queue Elements", "\n".join(queue))

# Display Queue
def display_queue():
    listbox.delete(0, tk.END)
    for item in queue:
        listbox.insert(tk.END, item)

# Check Empty
def check_empty():
    if len(queue) == 0:
        messagebox.showinfo("Queue", "Queue is Empty")
    else:
        messagebox.showinfo("Queue", "Queue is Not Empty")

# Check Full
def check_full():
    if len(queue) == max_size:
        messagebox.showinfo("Queue", "Queue is Full")
    else:
        messagebox.showinfo("Queue", "Queue is Not Full")

# ---------------- GUI ----------------

root = tk.Tk()
root.title("Queue Operations")
root.geometry("450x500")

max_size = 0

tk.Label(root, text="Enter Queue Size", font=("Arial", 12)).pack(pady=5)
size_entry = tk.Entry(root)
size_entry.pack()

tk.Button(root, text="Set Size", command=set_size).pack(pady=5)

tk.Label(root, text="Enter Item", font=("Arial", 12)).pack(pady=5)
item_entry = tk.Entry(root)
item_entry.pack()

tk.Button(root, text="Enqueue", width=20, command=enqueue).pack(pady=3)
tk.Button(root, text="Dequeue", width=20, command=dequeue).pack(pady=3)
tk.Button(root, text="Peek", width=20, command=peek).pack(pady=3)
tk.Button(root, text="Traverse", width=20, command=traverse).pack(pady=3)
tk.Button(root, text="Display Queue", width=20, command=display_queue).pack(pady=3)
tk.Button(root, text="Check Empty", width=20, command=check_empty).pack(pady=3)
tk.Button(root, text="Check Full", width=20, command=check_full).pack(pady=3)
tk.Button(root, text="Exit", width=20, command=root.destroy, bg="red", fg="white").pack(pady=10)

tk.Label(root, text="Queue Contents", font=("Arial", 12, "bold")).pack()

listbox = tk.Listbox(root, width=40, height=8)
listbox.pack(pady=5)

root.mainloop()